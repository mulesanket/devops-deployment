{
  "//": "Disable format-on-save for YAML in this workspace. We've had repeated incidents of a formatter collapsing newlines in deployment.yaml between `matchLabelKeys` list items and the next mapping key. See docs/jenkins/05-cd-strategy.md.",
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "[yaml]": {
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false,
    "editor.formatOnType": false,
    "editor.defaultFormatter": null
  },
  "[groovy]": {
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false,
    "editor.defaultFormatter": null
  },
  "[dockerfile]": {
    "editor.formatOnSave": false
  },
  "[terraform]": {
    "editor.formatOnSave": false
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n"
}
