// ============================================================
// Shopease — auth-service CI/CD pipeline (EKS agent + Kaniko)
//
// This pipeline runs entirely on an ephemeral build pod scheduled
// on the EKS cluster. The Jenkins controller (on EC2) only
// orchestrates; no docker daemon, no host tools required.
//
// Pod template (from shared library):
//   - jnlp   : Jenkins agent process (default container)
//   - maven  : mvn verify
//   - kaniko : daemonless image build + push to ECR (IRSA auth)
//   - aws    : aws CLI for STS / ECR describe (IRSA auth)
//   - tools  : trivy (vuln + secret scan), jq
//
// AWS auth: IRSA on ServiceAccount jenkins-agent-builder
// (role: shopease-webapp-development-ci-agent-irsa)
// ============================================================

@Library('shopease-jenkins-library') _

pipeline {
    agent {
        kubernetes {
            yaml shopeaseAgent(serviceName: 'auth-service')
            defaultContainer 'jnlp'
        }
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '5', daysToKeepStr: '30'))
    }    environment {
        SERVICE_NAME  = 'auth-service'
        AWS_REGION    = 'ap-south-1'
        ECR_REPO_NAME = "shopease-webapp-development-${SERVICE_NAME}"
        // BRANCH_NAME is only auto-set by multibranch jobs; fall back to
        // GIT_BRANCH (classic pipeline) or 'development' so downstream
        // string interpolation never produces "null-latest".
        SAFE_BRANCH   = "${env.BRANCH_NAME ?: env.GIT_BRANCH?.replaceAll('^origin/', '') ?: 'development'}"
    }

    stages {

        // -------------------------------------------------------------
        // 1. Setup & Environment
        // -------------------------------------------------------------
        stage('Setup & Environment') {
            steps {
                container('aws') {
                    script {
                        logger.stageHeader('Setup & Environment')

                        env.AWS_ACCOUNT_ID = sh(
                            script: 'aws sts get-caller-identity --query Account --output text',
                            returnStdout: true
                        ).trim()

                        env.ECR_REPO  = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com/${env.ECR_REPO_NAME}"
                        env.GIT_SHA   = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                        env.IMAGE_TAG = "${env.GIT_SHA}"
                        env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                        logger.logInfo("Service     : ${env.SERVICE_NAME}")
                        logger.logInfo("AWS Account : ${env.AWS_ACCOUNT_ID}")
                        logger.logInfo("AWS Region  : ${env.AWS_REGION}")
                        logger.logInfo("Branch      : ${env.BRANCH_NAME}")
                        logger.logInfo("Git SHA     : ${env.GIT_SHA}")
                        logger.logInfo("Image URI   : ${env.IMAGE_URI}")
                        logger.logInfo("Workspace   : ${env.WORKSPACE}")
                        logger.logInfo("Pod node    : ${env.NODE_NAME}")

                        sh '''
                            echo "-- IRSA caller identity (should be ci-agent-irsa) --"
                            aws sts get-caller-identity --output table
                        '''

                        logger.logSuccess('Setup & Environment completed')
                    }
                }
            }
        }

        // -------------------------------------------------------------
        // 2. Secret Scan (trivy fs --scanners secret)
        // -------------------------------------------------------------
        stage('Secret Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Secret Scan - Trivy secret') }

                    sh '''
                        set -e
                        echo "-- Running trivy secret scan ------------------"
                        trivy --version

                        trivy fs \
                            --scanners secret \
                            --exit-code 1 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-secrets-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Secret findings ----------------------------"
                        trivy convert \
                            --format table \
                            --scanners secret \
                            "${WORKSPACE}/trivy-secrets-report.json"

                        echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy secret report if available') }
                    archiveArtifacts artifacts: 'trivy-secrets-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
                failure { script { logger.logError('Secret scan failed: secrets detected. Inspect the archived report.') } }
            }
        }

        // -------------------------------------------------------------
        // 3. Dependency Vulnerability Scan (trivy fs --scanners vuln)
        // -------------------------------------------------------------
        stage('Dependency Vulnerability Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Dependency Vulnerability Scan - Trivy fs') }                    sh '''
                        set -e
                        echo "-- Running trivy fs (vuln) --------------------"
                        trivy --version

                        # First pass: full JSON report, never fail (exit-code 0).
                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 0 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-fs-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Findings (HIGH / CRITICAL only) ------------"
                        trivy convert \
                            --format table \
                            --severity HIGH,CRITICAL \
                            --scanners vuln \
                            "${WORKSPACE}/trivy-fs-report.json"

                        echo ""
                        echo "-- Gate (fail on any HIGH/CRITICAL) -----------"
                        # Second pass: identical scan, but let trivy enforce
                        # the gate via --exit-code 1 (avoids needing jq).
                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 1 \
                            --no-progress \
                            --quiet \
                            "application-backend/${SERVICE_NAME}"

                        echo "\\033[1;32mSUCCESS: No HIGH/CRITICAL vulnerabilities in dependencies.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy fs report if available') }
                    archiveArtifacts artifacts: 'trivy-fs-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        // -------------------------------------------------------------
        // 4. Build & Unit Tests (Maven container)
        // -------------------------------------------------------------
        stage('Build & Unit Tests') {
            steps {
                container('maven') {
                    script {
                        logger.stageHeader('Build & Unit Tests')
                        logger.logInfo('Running mvn verify inside maven:3.9-eclipse-temurin-21 container')
                    }

                    sh '''
                        set -e
                        echo "-- Toolchain ----------------------------------"
                        mvn -v

                        echo ""
                        echo "-- Running mvn verify -------------------------"
                        cd application-backend
                        mvn -pl ${SERVICE_NAME} -am -B -ntp verify

                        echo ""
                        echo "-- Test report locations ----------------------"
                        find . -type d -name surefire-reports | head -20
                        find . -type f -name jacoco.xml      | head -20

                        echo "\\033[1;32mSUCCESS: Build and unit tests completed.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Publishing JUnit results and coverage reports') }
                    junit testResults: 'application-backend/**/target/surefire-reports/*.xml',
                          allowEmptyResults: false,
                          skipPublishingChecks: true
                    recordCoverage(
                        tools: [[parser: 'JACOCO', pattern: 'application-backend/**/target/site/jacoco/jacoco.xml']],
                        sourceCodeRetention: 'EVERY_BUILD',
                        sourceDirectories: [[path: 'application-backend/auth-service/src/main/java']]
                    )
                    archiveArtifacts artifacts: 'application-backend/**/target/site/jacoco/jacoco.xml',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
                success { script { logger.logSuccess('Build & Unit Tests stage completed') } }
                failure { script { logger.logError('Build & Unit Tests failed. Check JUnit report or compile errors above.') } }
            }
        }

        // -------------------------------------------------------------
        // 5. Image Build & Push (Kaniko -> ECR)
        //    Kaniko builds and pushes in one step (daemonless).
        //    ECR auth uses the AWS SDK bundled in the kaniko -debug
        //    image, which picks up IRSA env vars automatically.
        // -------------------------------------------------------------
        stage('Image Build & Push') {
            steps {
                container('kaniko') {
                    script {
                        logger.stageHeader('Image Build & Push (Kaniko)')
                        logger.logInfo("Building & pushing : ${env.IMAGE_URI}")
                    }

                    sh '''
                        set -e
                        echo "-- Kaniko version -----------------------------"
                        /kaniko/executor version || true

                        echo ""
                        echo "-- Building & pushing image -------------------"
                        echo "Dockerfile  : application-backend/${SERVICE_NAME}/Dockerfile"
                        echo "Context     : application-backend/"
                        echo "Destination : ${IMAGE_URI}"
                        echo ""                        /kaniko/executor \
                            --context "${WORKSPACE}/application-backend" \
                            --dockerfile "${SERVICE_NAME}/Dockerfile" \
                            --destination "${IMAGE_URI}" \
                            --destination "${ECR_REPO}:${SAFE_BRANCH}-latest" \
                            --label "git.sha=${GIT_SHA}" \
                            --label "git.branch=${SAFE_BRANCH}" \
                            --label "build.number=${BUILD_NUMBER}" \
                            --label "service=${SERVICE_NAME}" \
                            --snapshot-mode=redo \
                            --use-new-run \
                            --log-format=text \
                            --verbosity=info

                        echo ""
                        echo "\\033[1;32mSUCCESS: Image built and pushed to ECR.\\033[0m"
                    '''
                }
            }
            post {
                success { script { logger.logSuccess("Image Build & Push completed: ${env.IMAGE_URI}") } }
                failure { script { logger.logError('Kaniko build/push failed. Check Dockerfile, IRSA perms (ecr:PutImage), or registry connectivity.') } }
            }
        }

        // -------------------------------------------------------------
        // 6. Image Vulnerability Scan (trivy image — against ECR)
        // -------------------------------------------------------------
        stage('Image Vulnerability Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Image Vulnerability Scan - Trivy image (ECR)') }

                    sh '''
                        set -e
                        echo "-- Running trivy image ------------------------"
                        trivy --version

                        export TMPDIR="${WORKSPACE}/.trivy-tmp"
                        mkdir -p "${TMPDIR}"
                    '''

                    retry(2) {
                        sh '''
                            set -e
                            export TMPDIR="${WORKSPACE}/.trivy-tmp"

                            # Trivy uses the AWS SDK (IRSA env vars injected by EKS)
                            # to obtain ECR auth tokens automatically.
                            trivy image \
                                --scanners vuln \
                                --severity HIGH,CRITICAL \
                                --ignore-unfixed \
                                --exit-code 0 \
                                --no-progress \
                                --format json \
                                --output "${WORKSPACE}/trivy-image-report.json" \
                                "${IMAGE_URI}"
                        '''
                    }                    sh '''
                        set -e
                        echo ""
                        echo "-- Findings (HIGH / CRITICAL, fixed-only) -----"
                        trivy convert \
                            --format table \
                            --severity HIGH,CRITICAL \
                            --scanners vuln \
                            "${WORKSPACE}/trivy-image-report.json"

                        echo ""
                        echo "-- Gate (fail on fixable HIGH/CRITICAL) -------"
                        # Trivy enforces the gate directly; avoids needing jq.
                        trivy image \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --ignore-unfixed \
                            --exit-code 1 \
                            --no-progress \
                            --quiet \
                            "${IMAGE_URI}"

                        echo "\\033[1;32mSUCCESS: No fixable HIGH/CRITICAL vulnerabilities in image.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy image report if available') }
                    archiveArtifacts artifacts: 'trivy-image-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                    sh 'rm -rf "${WORKSPACE}/.trivy-tmp" || true'
                }
                success { script { logger.logSuccess('Image Vulnerability Scan stage completed') } }
                failure { script { logger.logError('Image Vulnerability Scan failed: fixable CVEs found or trivy errored.') } }
            }
        }

        // -------------------------------------------------------------
        // 7. Verify ECR Push (aws describe-images)
        // -------------------------------------------------------------
        stage('Verify ECR Push') {
            steps {
                container('aws') {
                    script {
                        logger.stageHeader('Verify ECR Push')
                        logger.logInfo("Verifying image : ${env.IMAGE_URI}")
                    }

                    retry(2) {
                        sh '''
                            set -e
                            echo "-- Describing image in ECR --------------------"
                            aws ecr describe-images \
                                --repository-name "${ECR_REPO_NAME}" \
                                --image-ids "imageTag=${GIT_SHA}" \
                                --region "${AWS_REGION}" \
                                --query 'imageDetails[0].{Tag:imageTags[0],Digest:imageDigest,Pushed:imagePushedAt,SizeBytes:imageSizeInBytes}' \
                                --output table

                            echo ""
                            echo "\\033[1;32mSUCCESS: Image verified in ECR.\\033[0m"
                        '''
                    }
                }
            }
            post {
                success { script { logger.logSuccess("ECR verification completed: ${env.IMAGE_URI}") } }
                failure { script { logger.logError('ECR verification failed. Image may not have been pushed; check Kaniko logs.') } }
            }
        }

        // -------------------------------------------------------------
        // 8. Build Summary
        //    (No host cleanup needed — the agent pod is destroyed
        //     automatically when the build ends.)
        // -------------------------------------------------------------
        stage('Build Summary') {
            steps {
                script {
                    logger.stageHeader('Build Summary')
                    echo logger.color('1;36', """
============================================================
 BUILD SUMMARY
============================================================
 Service     : ${env.SERVICE_NAME}
 Branch      : ${env.BRANCH_NAME}
 Git SHA     : ${env.GIT_SHA}
 Image URI   : ${env.IMAGE_URI}
 Build #     : ${env.BUILD_NUMBER}
 Agent pod   : ${env.NODE_NAME}
 Result      : ${currentBuild.currentResult}
============================================================
""")
                }
            }
        }
    }

    post {
        success  { script { logger.logSuccess("Pipeline completed successfully. Build #${env.BUILD_NUMBER}") } }
        failure  { script { logger.logError("Pipeline failed. Build #${env.BUILD_NUMBER}") } }
        unstable { script { logger.logWarning("Pipeline unstable. Build #${env.BUILD_NUMBER}") } }
        always   { script { logger.logInfo("Build #${env.BUILD_NUMBER} finished with status: ${currentBuild.currentResult}") } }
    }
}
