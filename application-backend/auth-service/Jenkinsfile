@Library('shopease-jenkins-library') _

pipeline {
    agent {
        kubernetes {
            yaml shopeaseAgent(serviceName: 'auth-service')
            defaultContainer 'jnlp'
            showRawYaml false
        }
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '5', daysToKeepStr: '30'))
    }        
    
    environment {
        SERVICE_NAME    = 'auth-service'
        AWS_REGION      = 'ap-south-1'
        ECR_REPO_NAME   = "shopease-webapp-development-${SERVICE_NAME}"
        SAFE_BRANCH     = "${env.BRANCH_NAME ?: env.GIT_BRANCH?.replaceAll('^origin/', '') ?: 'development'}"
        ARTIFACT_BUCKET = 'shopease-webapp-development-ci-artifacts'

        CACHE_S3_M2    = "s3://shopease-webapp-development-ci-artifacts/_caches/${SERVICE_NAME}/m2.tar.gz"
        CACHE_S3_TRIVY = "s3://shopease-webapp-development-ci-artifacts/_caches/_shared/trivy-db.tar.gz"
    }

    stages {

        stage('Setup & Environment') {
            steps {
                container('aws') {
                    script {
                        logger.stageHeader('Setup & Environment')

                        env.AWS_ACCOUNT_ID = sh(
                            script: 'aws sts get-caller-identity --query Account --output text',
                            returnStdout: true
                        ).trim()

                        env.ECR_REPO  = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com/${env.ECR_REPO_NAME}"
                        env.GIT_SHA   = (env.GIT_COMMIT ?: 'unknown').take(7)
                        env.IMAGE_TAG = "${env.GIT_SHA}"
                        env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                        logger.logInfo("Service     : ${env.SERVICE_NAME}")
                        logger.logInfo("AWS Account : ${env.AWS_ACCOUNT_ID}")
                        logger.logInfo("AWS Region  : ${env.AWS_REGION}")
                        logger.logInfo("Branch      : ${env.BRANCH_NAME}")
                        logger.logInfo("Git SHA     : ${env.GIT_SHA}")
                        logger.logInfo("Image URI   : ${env.IMAGE_URI}")
                        logger.logInfo("Workspace   : ${env.WORKSPACE}")
                        logger.logInfo("Pod node    : ${env.NODE_NAME}")

                        sh '''
                            echo "-- IRSA caller identity (should be ci-agent-irsa) --"
                            aws sts get-caller-identity --output table
                        '''

                        logger.logSuccess('Setup & Environment completed')
                    }
                }
            }
        }

        stage('Restore Caches') {
            steps {
                container('aws') {
                    script { logger.stageHeader('Restore Caches from S3') }

                    sh '''
                        set +e
                        mkdir -p "${WORKSPACE}/.cache"

                        echo "-- Restoring Maven .m2 cache from S3 ---------"
                        if aws s3 cp "${CACHE_S3_M2}" "${WORKSPACE}/.cache/m2.tar.gz" --no-progress 2>/dev/null; then
                            ls -lh "${WORKSPACE}/.cache/m2.tar.gz"
                            echo "Maven cache tarball downloaded."
                        else
                            echo "WARN: no Maven cache in S3 yet (first build for this service). Continuing cold."
                        fi

                        echo ""
                        echo "-- Restoring Trivy DB cache from S3 ----------"
                        if aws s3 cp "${CACHE_S3_TRIVY}" "${WORKSPACE}/.cache/trivy-db.tar.gz" --no-progress 2>/dev/null; then
                            ls -lh "${WORKSPACE}/.cache/trivy-db.tar.gz"
                            echo "Trivy cache tarball downloaded."
                        else
                            echo "WARN: no Trivy cache in S3 yet. Continuing cold."
                        fi

                        exit 0
                    '''
                }

                container('maven') {
                    sh '''
                        set +e
                        if [ -f "${WORKSPACE}/.cache/m2.tar.gz" ]; then
                            mkdir -p /root/.m2
                            echo "-- Extracting Maven cache into /root/.m2 -----"
                            tar -xzf "${WORKSPACE}/.cache/m2.tar.gz" -C /root/.m2
                            echo "Maven cache restored. Contents:"
                            du -sh /root/.m2/repository 2>/dev/null || true
                        else
                            echo "No Maven cache to extract; skipping."
                        fi
                        exit 0
                    '''
                }

                container('tools') {
                    sh '''
                        set +e
                        if [ -f "${WORKSPACE}/.cache/trivy-db.tar.gz" ]; then
                            mkdir -p /root/.cache/trivy
                            echo "-- Extracting Trivy DB cache into /root/.cache/trivy --"
                            tar -xzf "${WORKSPACE}/.cache/trivy-db.tar.gz" -C /root/.cache/trivy
                            echo "Trivy cache restored. Contents:"
                            du -sh /root/.cache/trivy 2>/dev/null || true
                        else
                            echo "No Trivy cache to extract; skipping."
                        fi
                        exit 0
                    '''
                }

                script { logger.logSuccess('Restore Caches completed (cache misses are non-fatal)') }
            }
        }

        stage('Secret Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Secret Scan - Trivy secret') }

                    sh '''
                        set -e
                        echo "-- Running trivy secret scan ------------------"
                        trivy --version
                        trivy fs \
                            --scanners secret \
                            --exit-code 1 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-secrets-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Secret findings ----------------------------"
                        trivy convert \
                            --format table \
                            "${WORKSPACE}/trivy-secrets-report.json"

                        echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                    '''
                }
            }
        }

        stage('Dependency Vulnerability Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Dependency Vulnerability Scan - Trivy fs') }

                    sh '''
                        set -e
                        echo "-- Running trivy fs (vuln) --------------------"
                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 1 \
                            --no-progress \
                            "application-backend/${SERVICE_NAME}"
                    '''
                }
            }
        }

        stage('Build & Unit Tests') {
            steps {
                container('maven') {
                    sh '''
                        set -e
                        cd application-backend
                        mvn -pl ${SERVICE_NAME} -am -B -ntp verify
                    '''
                }
            }
        }

        stage('Image Build & Push') {
            steps {
                container('kaniko') {
                    sh '''
                        set -e
                        /kaniko/executor \
                            --context "${WORKSPACE}/application-backend" \
                            --dockerfile "${SERVICE_NAME}/Dockerfile" \
                            --destination "${IMAGE_URI}"
                    '''
                }
            }
        }

        stage('Verify ECR Push') {
            steps {
                container('aws') {
                    sh '''
                        aws ecr describe-images \
                            --repository-name "${ECR_REPO_NAME}" \
                            --image-ids "imageTag=${GIT_SHA}" \
                            --region "${AWS_REGION}"
                    '''
                }
            }
        }

        stage('Verify ECR Push') {
            steps {
                container('aws') {
                    sh '''
                        aws ecr describe-images \
                            --repository-name "${ECR_REPO_NAME}" \
                            --image-ids "imageTag=${GIT_SHA}" \
                            --region "${AWS_REGION}"
                    '''
                }
            }
        }

        stage('Build Summary') {
            steps {
                script {
                    echo """
============================================================
 BUILD SUMMARY
============================================================
 Service     : ${env.SERVICE_NAME}
 Branch      : ${env.BRANCH_NAME}
 Git SHA     : ${env.GIT_SHA}
 Image URI   : ${env.IMAGE_URI}
 Build #     : ${env.BUILD_NUMBER}
 Agent pod   : ${env.NODE_NAME}
 Artifacts   : s3://${env.ARTIFACT_BUCKET}/${env.SERVICE_NAME}/ (prefix: ${env.SERVICE_NAME}-${env.GIT_SHA}-${env.BUILD_NUMBER})
 Result      : ${currentBuild.currentResult}
============================================================
"""
                }
            }
        }
    }
}