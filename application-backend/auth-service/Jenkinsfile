@Library('shopease-jenkins-library') _

pipeline {
    agent {
        kubernetes {
            yaml shopeaseAgent(serviceName: 'auth-service')
            defaultContainer 'jnlp'
        }
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '5', daysToKeepStr: '30'))
    }

    environment {
        SERVICE_NAME  = 'auth-service'
        AWS_REGION    = 'ap-south-1'
        ECR_REPO_NAME = "shopease-webapp-development-${SERVICE_NAME}"
        SAFE_BRANCH   = "${env.BRANCH_NAME ?: env.GIT_BRANCH?.replaceAll('^origin/', '') ?: 'development'}"
    }

    stages {

        stage('Setup & Environment') {
            steps {
                container('aws') {
                    script {
                        logger.stageHeader('Setup & Environment')

                        env.AWS_ACCOUNT_ID = sh(
                            script: 'aws sts get-caller-identity --query Account --output text',
                            returnStdout: true
                        ).trim()                        env.ECR_REPO  = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com/${env.ECR_REPO_NAME}"
                        // GIT_COMMIT is populated by the implicit `checkout scm`
                        // performed before stages start. Use it instead of
                        // shelling out to `git` (not installed in aws image).
                        env.GIT_SHA   = (env.GIT_COMMIT ?: 'unknown').take(7)
                        env.IMAGE_TAG = "${env.GIT_SHA}"
                        env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                        logger.logInfo("Service     : ${env.SERVICE_NAME}")
                        logger.logInfo("AWS Account : ${env.AWS_ACCOUNT_ID}")
                        logger.logInfo("AWS Region  : ${env.AWS_REGION}")
                        logger.logInfo("Branch      : ${env.BRANCH_NAME}")
                        logger.logInfo("Git SHA     : ${env.GIT_SHA}")
                        logger.logInfo("Image URI   : ${env.IMAGE_URI}")
                        logger.logInfo("Workspace   : ${env.WORKSPACE}")
                        logger.logInfo("Pod node    : ${env.NODE_NAME}")

                        sh '''
                            echo "-- IRSA caller identity (should be ci-agent-irsa) --"
                            aws sts get-caller-identity --output table
                        '''

                        logger.logSuccess('Setup & Environment completed')
                    }
                }
            }
        }

        stage('Secret Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Secret Scan - Trivy secret') }

                    sh '''
                        set -e
                        echo "-- Running trivy secret scan ------------------"
                        trivy --version

                        trivy fs \
                            --scanners secret \
                            --exit-code 1 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-secrets-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Secret findings ----------------------------"
                        trivy convert \
                            --format table \
                            --scanners secret \
                            "${WORKSPACE}/trivy-secrets-report.json"

                        echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy secret report if available') }
                    archiveArtifacts artifacts: 'trivy-secrets-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
                failure { script { logger.logError('Secret scan failed: secrets detected. Inspect the archived report.') } }
            }
        }

        stage('Dependency Vulnerability Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Dependency Vulnerability Scan - Trivy fs') }

                    sh '''
                        set -e
                        echo "-- Running trivy fs (vuln) --------------------"
                        trivy --version

                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 0 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-fs-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Findings (HIGH / CRITICAL only) ------------"
                        trivy convert \
                            --format table \
                            --severity HIGH,CRITICAL \
                            --scanners vuln \
                            "${WORKSPACE}/trivy-fs-report.json"

                        echo ""
                        echo "-- Gate (fail on any HIGH/CRITICAL) -----------"
                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 1 \
                            --no-progress \
                            --quiet \
                            "application-backend/${SERVICE_NAME}"

                        echo "\\033[1;32mSUCCESS: No HIGH/CRITICAL vulnerabilities in dependencies.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy fs report if available') }
                    archiveArtifacts artifacts: 'trivy-fs-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Build & Unit Tests') {
            steps {
                container('maven') {
                    script {
                        logger.stageHeader('Build & Unit Tests')
                        logger.logInfo('Running mvn verify inside maven container')
                    }

                    sh '''
                        set -e
                        echo "-- Toolchain ----------------------------------"
                        mvn -v

                        echo ""
                        echo "-- Running mvn verify -------------------------"
                        cd application-backend
                        mvn -pl ${SERVICE_NAME} -am -B -ntp verify

                        echo ""
                        echo "-- Test report locations ----------------------"
                        find . -type d -name surefire-reports | head -20
                        find . -type f -name jacoco.xml      | head -20

                        echo "\\033[1;32mSUCCESS: Build and unit tests completed.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Publishing JUnit results and coverage reports') }
                    junit testResults: 'application-backend/**/target/surefire-reports/*.xml',
                          allowEmptyResults: false,
                          skipPublishingChecks: true
                }
            }
        }

        stage('Image Build & Push') {
            steps {
                container('kaniko') {
                    script {
                        logger.stageHeader('Image Build & Push (Kaniko)')
                        logger.logInfo("Building & pushing : ${env.IMAGE_URI}")
                    }

                    sh '''
                        set -e
                        /kaniko/executor \
                            --context "${WORKSPACE}/application-backend" \
                            --dockerfile "${SERVICE_NAME}/Dockerfile" \
                            --destination "${IMAGE_URI}" \
                            --destination "${ECR_REPO}:${SAFE_BRANCH}-latest" \
                            --label "git.sha=${GIT_SHA}" \
                            --label "git.branch=${SAFE_BRANCH}" \
                            --label "build.number=${BUILD_NUMBER}" \
                            --label "service=${SERVICE_NAME}" \
                            --snapshot-mode=redo \
                            --use-new-run \
                            --log-format=text \
                            --verbosity=info
                    '''
                }
            }
        }

        stage('Verify ECR Push') {
            steps {
                container('aws') {
                    sh '''
                        aws ecr describe-images \
                            --repository-name "${ECR_REPO_NAME}" \
                            --image-ids "imageTag=${GIT_SHA}" \
                            --region "${AWS_REGION}"
                    '''
                }
            }
        }

        stage('Build Summary') {
            steps {
                script {
                    echo """
============================================================
 BUILD SUMMARY
============================================================
 Service     : ${env.SERVICE_NAME}
 Branch      : ${env.BRANCH_NAME}
 Git SHA     : ${env.GIT_SHA}
 Image URI   : ${env.IMAGE_URI}
 Build #     : ${env.BUILD_NUMBER}
 Agent pod   : ${env.NODE_NAME}
 Result      : ${currentBuild.currentResult}
============================================================
"""
                }
            }
        }
    }
}