@Library('shopease-jenkins-library') _

pipeline {
    agent any

    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '3', daysToKeepStr: '30'))
    }

    environment {
        SERVICE_NAME = 'auth-service'
        AWS_REGION   = 'ap-south-1'
    }

    stages {

        // -------------------------------------------------------------
        // 1. Setup & Environment
        // -------------------------------------------------------------
        stage('Setup & Environment') {
            steps {
                script {
                    logger.stageHeader('Setup & Environment')

                    env.AWS_ACCOUNT_ID = sh(
                        script: 'aws sts get-caller-identity --query Account --output text',
                        returnStdout: true
                    ).trim()

                    env.ECR_REPO  = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com/shopease-webapp-development-${env.SERVICE_NAME}"
                    env.GIT_SHA   = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG = "${env.GIT_SHA}"
                    env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                    logger.logInfo("Service    : ${env.SERVICE_NAME}")
                    logger.logInfo("AWS Account: ${env.AWS_ACCOUNT_ID}")
                    logger.logInfo("AWS Region : ${env.AWS_REGION}")
                    logger.logInfo("Branch     : ${env.BRANCH_NAME}")
                    logger.logInfo("Git SHA    : ${env.GIT_SHA}")
                    logger.logInfo("Image URI  : ${env.IMAGE_URI}")
                    logger.logInfo("Workspace  : ${env.WORKSPACE}")

                    logger.logSuccess('Setup & Environment completed')
                }
            }
        }

        // -------------------------------------------------------------
        // 2. Secret Scan (gitleaks)
        // -------------------------------------------------------------
        stage('Secret Scan') {
            steps {
                script { logger.stageHeader('Secret Scan') }

                sh '''
                    set -e
                    echo "-- Running gitleaks ---------------------------"

                    if ! command -v gitleaks >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: gitleaks is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    gitleaks version

                    gitleaks detect \
                        --source="${WORKSPACE}" \
                        --no-git \
                        --report-format=json \
                        --report-path="${WORKSPACE}/gitleaks-report.json" \
                        --redact \
                        --verbose \
                        --exit-code=1

                    echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                '''
            }
            post {
                always {
                    script { logger.logWarning('Archiving gitleaks report if available') }
                    archiveArtifacts artifacts: 'gitleaks-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        // -------------------------------------------------------------
        // 3. Dependency Vulnerability Scan (trivy fs)
        // -------------------------------------------------------------
        stage('Dependency Vulnerability Scan') {
            steps {
                script { logger.stageHeader('Dependency Vulnerability Scan - Trivy fs') }

                sh '''
                    set -e
                    echo "-- Running trivy fs ---------------------------"

                    if ! command -v trivy >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: trivy is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    trivy --version
                    trivy fs \
                        --scanners vuln \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --no-progress \
                        --format json \
                        --output "${WORKSPACE}/trivy-fs-report.json" \
                        application-backend/${SERVICE_NAME}

                    echo ""
                    echo "-- Findings (HIGH / CRITICAL only) ------------"
                    trivy convert \
                        --format table \
                        --severity HIGH,CRITICAL \
                        --scanners vuln \
                        "${WORKSPACE}/trivy-fs-report.json"

                    HIGH_CRIT_COUNT=$(jq '[.Results[]?.Vulnerabilities[]?] | length' "${WORKSPACE}/trivy-fs-report.json")
                    echo ""
                    echo "Total HIGH/CRITICAL findings: ${HIGH_CRIT_COUNT}"

                    if [ "${HIGH_CRIT_COUNT}" -gt 0 ]; then
                        echo "\\033[1;31mFAIL: ${HIGH_CRIT_COUNT} HIGH/CRITICAL vulnerabilities found in dependencies.\\033[0m"
                        exit 1
                    fi

                    echo "\\033[1;32mSUCCESS: No HIGH/CRITICAL vulnerabilities in dependencies.\\033[0m"
                '''
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy fs report if available') }
                    archiveArtifacts artifacts: 'trivy-fs-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        // -------------------------------------------------------------
        // 4. Build & Unit Tests (containerized Maven)
        // -------------------------------------------------------------
        stage('Build & Unit Tests') {
            steps {
                script {
                    logger.stageHeader('Build & Unit Tests')
                    logger.logInfo('Running Maven verify inside containerized toolchain (maven:3.9-eclipse-temurin-21)')
                }

                sh '''
                    set -e
                    echo "-- Pre-flight checks --------------------------"

                    if ! command -v docker >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: docker is required to run the containerized Maven build.\\033[0m"
                        exit 1
                    fi

                    mkdir -p /var/lib/jenkins/.m2

                    echo ""
                    echo "-- Pulling Maven image ------------------------"
                    docker pull maven:3.9-eclipse-temurin-21

                    echo ""
                    echo "-- Running mvn verify -------------------------"
                    docker run --rm \
                        -v "${WORKSPACE}":/workspace \
                        -v /var/lib/jenkins/.m2:/root/.m2 \
                        -w /workspace/application-backend \
                        maven:3.9-eclipse-temurin-21 \
                        mvn -pl ${SERVICE_NAME} -am -B -ntp verify

                    echo ""
                    echo "-- Test report locations ----------------------"
                    find application-backend -type d -name surefire-reports | head -20
                    find application-backend -type f -name jacoco.xml      | head -20

                    echo ""
                    echo "\\033[1;32mSUCCESS: Build and unit tests completed.\\033[0m"
                '''
            }
            post {
                always {
                    script { logger.logWarning('Publishing JUnit results and coverage reports') }
                    junit testResults: 'application-backend/**/target/surefire-reports/*.xml',
                          allowEmptyResults: false,
                          skipPublishingChecks: true
                    recordCoverage(
                        tools: [[parser: 'JACOCO', pattern: 'application-backend/**/target/site/jacoco/jacoco.xml']],
                        sourceCodeRetention: 'EVERY_BUILD',
                        sourceDirectories: [[path: 'application-backend/auth-service/src/main/java']]
                    )
                    archiveArtifacts artifacts: 'application-backend/**/target/site/jacoco/jacoco.xml',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
                success { script { logger.logSuccess('Build & Unit Tests stage completed') } }
                failure { script { logger.logError('Build & Unit Tests failed. Check JUnit report or compile errors above.') } }
            }
        }

        // -------------------------------------------------------------
        // 5. Docker Build
        // -------------------------------------------------------------
        stage('Docker Build') {
            steps {
                script {
                    logger.stageHeader('Docker Build')
                    logger.logInfo("Building image: ${env.IMAGE_URI}")
                }

                sh '''
                    set -e
                    echo "-- Pre-flight checks --------------------------"

                    if ! command -v docker >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: docker is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    if ! docker info >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: cannot talk to docker daemon. Is the jenkins user in the docker group?\\033[0m"
                        exit 1
                    fi

                    docker --version

                    echo ""
                    echo "-- Building image -----------------------------"
                    echo "Dockerfile : application-backend/${SERVICE_NAME}/Dockerfile"
                    echo "Context    : application-backend/"
                    echo "Tag        : ${IMAGE_URI}"
                    echo ""

                    docker build \
                        --pull \
                        --progress=plain \
                        --file application-backend/${SERVICE_NAME}/Dockerfile \
                        --tag "${IMAGE_URI}" \
                        --label "git.sha=${GIT_SHA}" \
                        --label "git.branch=${BRANCH_NAME}" \
                        --label "build.number=${BUILD_NUMBER}" \
                        --label "service=${SERVICE_NAME}" \
                        application-backend

                    echo ""
                    echo "-- Image details ------------------------------"
                    docker images "${ECR_REPO}" --format "table {{.Repository}}\\t{{.Tag}}\\t{{.ID}}\\t{{.Size}}" | head -5

                    echo ""
                    echo "\\033[1;32mSUCCESS: Image built and tagged.\\033[0m"
                '''
            }
            post {
                success { script { logger.logSuccess("Docker Build stage completed: ${env.IMAGE_URI}") } }
                failure { script { logger.logError('Docker Build failed. Check the Dockerfile step that errored.') } }
            }
        }

        // -------------------------------------------------------------
        // 6. Image Vulnerability Scan (trivy image)
        // -------------------------------------------------------------
        stage('Image Vulnerability Scan') {
            steps {
                script { logger.stageHeader('Image Vulnerability Scan - Trivy image') }

                sh '''
                    set -e
                    echo "-- Running trivy image ------------------------"

                    if ! command -v trivy >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: trivy is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    trivy --version

                    export TMPDIR="${WORKSPACE}/.trivy-tmp"
                    mkdir -p "${TMPDIR}"
                '''

                retry(2) {
                    sh '''
                        set -e
                        export TMPDIR="${WORKSPACE}/.trivy-tmp"

                        trivy image \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --ignore-unfixed \
                            --exit-code 0 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-image-report.json" \
                            "${IMAGE_URI}"
                    '''
                }

                sh '''
                    set -e
                    echo ""
                    echo "-- Findings (HIGH / CRITICAL, fixed-only) ----"
                    trivy convert \
                        --format table \
                        --severity HIGH,CRITICAL \
                        --scanners vuln \
                        "${WORKSPACE}/trivy-image-report.json"

                    HIGH_CRIT_COUNT=$(jq '[.Results[]?.Vulnerabilities[]?] | length' "${WORKSPACE}/trivy-image-report.json")
                    echo ""
                    echo "Total HIGH/CRITICAL (fixed) findings in image: ${HIGH_CRIT_COUNT}"

                    if [ "${HIGH_CRIT_COUNT}" -gt 0 ]; then
                        echo "\\033[1;31mFAIL: ${HIGH_CRIT_COUNT} HIGH/CRITICAL vulnerabilities in image with available fixes.\\033[0m"
                        echo "Remediation: bump the base image tag in the Dockerfile (eclipse-temurin) and rebuild."
                        exit 1
                    fi

                    echo "\\033[1;32mSUCCESS: No fixable HIGH/CRITICAL vulnerabilities in image.\\033[0m"
                '''
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy image report if available') }
                    archiveArtifacts artifacts: 'trivy-image-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                    sh 'rm -rf "${WORKSPACE}/.trivy-tmp" || true'
                }
                success { script { logger.logSuccess('Image Vulnerability Scan stage completed') } }
                failure { script { logger.logError('Image Vulnerability Scan failed: fixable CVEs found or trivy errored.') } }
            }
        }

        // -------------------------------------------------------------
        // 7. ECR Login & Push
        // -------------------------------------------------------------
        stage('ECR Login & Push') {
            steps {
                script {
                    logger.stageHeader('ECR Login & Push')
                    logger.logInfo("Target registry: ${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com")
                    logger.logInfo("Pushing image  : ${env.IMAGE_URI}")
                }

                sh '''
                    set -e
                    echo "-- Pre-flight checks --------------------------"

                    if ! command -v aws >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: aws CLI is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    aws --version
                    echo ""
                    echo "Caller identity (must have ecr:* perms on this repo):"
                    aws sts get-caller-identity --output table
                '''

                retry(2) {
                    sh '''
                        set -e
                        echo ""
                        echo "-- Docker login to ECR ------------------------"

                        aws ecr get-login-password --region "${AWS_REGION}" \
                            | docker login \
                                --username AWS \
                                --password-stdin \
                                "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                    '''
                }

                retry(2) {
                    sh '''
                        set -e
                        echo ""
                        echo "-- Pushing image ------------------------------"
                        echo "Image: ${IMAGE_URI}"
                        docker push "${IMAGE_URI}"
                    '''
                }

                retry(2) {
                    sh '''
                        set -e
                        echo ""
                        echo "-- Verifying image in ECR ---------------------"
                        aws ecr describe-images \
                            --repository-name "shopease-webapp-development-${SERVICE_NAME}" \
                            --image-ids "imageTag=${GIT_SHA}" \
                            --region "${AWS_REGION}" \
                            --query 'imageDetails[0].{Tag:imageTags[0],Digest:imageDigest,Pushed:imagePushedAt,SizeMB:imageSizeInBytes}' \
                            --output table

                        echo ""
                        echo "\\033[1;32mSUCCESS: Image pushed and verified in ECR.\\033[0m"
                    '''
                }
            }
            post {
                success { script { logger.logSuccess("ECR Push completed: ${env.IMAGE_URI}") } }
                failure { script { logger.logError('ECR Push failed. Check IAM perms (ecr:PutImage, ecr:UploadLayerPart) or network egress.') } }
                always  { sh 'docker logout "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com" || true' }
            }
        }

        // -------------------------------------------------------------
        // 8. Post-Build Cleanup & Summary
        // -------------------------------------------------------------
        stage('Post-Build Cleanup & Summary') {
            steps {
                script { logger.stageHeader('Post-Build Cleanup & Summary') }

                sh '''
                    set +e
                    echo "-- Removing local image -----------------------"
                    # Image is safely in ECR now; no reason to keep it on the
                    # Jenkins host. Leaving images behind fills the disk after
                    # a few dozen builds on a bare-metal agent.
                    docker rmi "${IMAGE_URI}" || true

                    echo ""
                    echo "-- Pruning dangling layers --------------------"
                    # Surgical: only dangling (untagged) intermediate layers.
                    # We intentionally do NOT run 'docker system prune -a'
                    # because that would wipe the base-image cache
                    # (eclipse-temurin, maven) and force a ~500MB re-pull
                    # on the next build.
                    docker image prune -f

                    echo ""
                    echo "-- Disk usage ---------------------------------"
                    df -h / | tail -2
                    docker system df
                '''

                script {
                    echo logger.color('1;36', """
============================================================
 BUILD SUMMARY
============================================================
 Service     : ${env.SERVICE_NAME}
 Branch      : ${env.BRANCH_NAME}
 Git SHA     : ${env.GIT_SHA}
 Image URI   : ${env.IMAGE_URI}
 Build #     : ${env.BUILD_NUMBER}
 Result      : ${currentBuild.currentResult}
============================================================
""")
                }
            }
        }
    }

    post {
        success  { script { logger.logSuccess("Pipeline completed successfully. Build #${env.BUILD_NUMBER}") } }
        failure  { script { logger.logError("Pipeline failed. Build #${env.BUILD_NUMBER}") } }
        unstable { script { logger.logWarning("Pipeline unstable. Build #${env.BUILD_NUMBER}") } }
        always   { script { logger.logInfo("Build #${env.BUILD_NUMBER} finished with status: ${currentBuild.currentResult}") } }
    }
}

