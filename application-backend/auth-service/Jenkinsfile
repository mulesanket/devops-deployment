def color(code, message) {
    return "\u001B[${code}m${message}\u001B[0m"
}

def stageHeader(String name) {
    echo color('1;36', """
============================================================
 STAGE STARTED: ${name}
============================================================
""")
}

def logSuccess(String message) {
    echo color('1;32', "SUCCESS: ${message}")
}

def logWarning(String message) {
    echo color('1;33', "WARNING: ${message}")
}

def logInfo(String message) {
    echo color('1;34', "INFO: ${message}")
}

def logError(String message) {
    echo color('1;31', "ERROR: ${message}")
}

pipeline {
    agent any

    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '3', daysToKeepStr: '30'))
    }

    environment {
        SERVICE_NAME   = 'auth-service'
        AWS_REGION     = 'ap-south-1'
        AWS_ACCOUNT_ID = '483829975256'
        ECR_REPO       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/shopease-webapp-development-${SERVICE_NAME}"
    }

    stages {

        stage('Setup & Environment') {
            steps {
                script {
                    stageHeader('Setup & Environment')

                    env.GIT_SHA   = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG = "${env.GIT_SHA}"
                    env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                    logInfo("Service   : ${env.SERVICE_NAME}")
                    logInfo("Branch    : ${env.BRANCH_NAME}")
                    logInfo("Git SHA   : ${env.GIT_SHA}")
                    logInfo("Image URI : ${env.IMAGE_URI}")
                    logInfo("Workspace : ${env.WORKSPACE}")

                    logSuccess('Setup & Environment completed')
                }
            }
        }

        stage('Secret Scan') {
            steps {
                script {
                    stageHeader('Secret Scan')
                }

                sh '''
                    echo "-- Running gitleaks ---------------------------"

                    if ! command -v gitleaks >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: gitleaks is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    gitleaks version

                    gitleaks detect \
                        --source="${WORKSPACE}" \
                        --no-git \
                        --report-format=json \
                        --report-path="${WORKSPACE}/gitleaks-report.json" \
                        --redact \
                        --verbose \
                        --exit-code=1

                    echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                '''
            }

            post {
                always {
                    script {
                        logWarning('Archiving gitleaks report if available')
                    }

                    archiveArtifacts artifacts: 'gitleaks-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Dependency Vulnerability Scan') {
            steps {
                script {
                    stageHeader('Dependency Vulnerability Scan - Trivy fs')
                }

                sh '''
                    set -e
                    echo "-- Running trivy fs ---------------------------"

                    if ! command -v trivy >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: trivy is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    trivy --version                    
                    trivy fs \
                        --scanners vuln \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --no-progress \
                        --format json \
                        --output "${WORKSPACE}/trivy-fs-report.json" \
                        application-backend/auth-service

                    echo ""
                    echo "-- Findings (HIGH / CRITICAL only) ------------"
                    trivy convert \
                        --format table \
                        --severity HIGH,CRITICAL \
                        --scanners vuln \
                        "${WORKSPACE}/trivy-fs-report.json"

                    HIGH_CRIT_COUNT=$(jq '[.Results[]?.Vulnerabilities[]?] | length' "${WORKSPACE}/trivy-fs-report.json")
                    echo ""
                    echo "Total HIGH/CRITICAL findings: ${HIGH_CRIT_COUNT}"

                    if [ "${HIGH_CRIT_COUNT}" -gt 0 ]; then
                        echo "\\033[1;31mFAIL: ${HIGH_CRIT_COUNT} HIGH/CRITICAL vulnerabilities found in dependencies.\\033[0m"
                        exit 1
                    fi

                    echo "\\033[1;32mSUCCESS: No HIGH/CRITICAL vulnerabilities in dependencies.\\033[0m"
                '''
            }            
            post {
                always {
                    script {
                        logWarning('Archiving trivy fs report if available')
                    }

                    archiveArtifacts artifacts: 'trivy-fs-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    stageHeader('Docker Build')
                    logInfo("Building image: ${env.IMAGE_URI}")
                }

                sh '''
                    set -e
                    echo "-- Pre-flight checks --------------------------"

                    if ! command -v docker >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: docker is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    if ! docker info >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: cannot talk to docker daemon. Is the jenkins user in the docker group?\\033[0m"
                        exit 1
                    fi

                    docker --version

                    echo ""
                    echo "-- Building image -----------------------------"
                    echo "Dockerfile : application-backend/auth-service/Dockerfile"
                    echo "Context    : application-backend/"
                    echo "Tag        : ${IMAGE_URI}"
                    echo ""                    

                    docker build \
                        --pull \
                        --progress=plain \
                        --file application-backend/auth-service/Dockerfile \
                        --tag "${IMAGE_URI}" \
                        --label "git.sha=${GIT_SHA}" \
                        --label "git.branch=${BRANCH_NAME}" \
                        --label "build.number=${BUILD_NUMBER}" \
                        --label "service=${SERVICE_NAME}" \
                        application-backend

                    echo ""
                    echo "-- Image details ------------------------------"
                    docker images "${ECR_REPO}" --format "table {{.Repository}}\\t{{.Tag}}\\t{{.ID}}\\t{{.Size}}" | head -5

                    echo ""
                    echo "\\033[1;32mSUCCESS: Image built and tagged.\\033[0m"
                '''
            }           
            post {
                success {
                    script {
                        logSuccess("Docker Build stage completed: ${env.IMAGE_URI}")
                    }
                }
                failure {
                    script {
                        logError('Docker Build failed. Check the build log for the Dockerfile step that errored.')
                    }
                }
            }
        }

        stage('Image Vulnerability Scan') {
            steps {                script {
                    stageHeader('Image Vulnerability Scan - Trivy image')
                }

                sh '''
                    set -e
                    echo "-- Running trivy image ------------------------"

                    if ! command -v trivy >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: trivy is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    trivy --version

                    # /tmp on this host is a 2GB tmpfs (RAM-backed). Trivy
                    # extracts image layers + downloads its Java DB into TMPDIR,
                    # which can exceed 2GB for a Spring Boot image. Redirect to
                    # a workspace-local scratch dir on real disk.
                    export TMPDIR="${WORKSPACE}/.trivy-tmp"
                    mkdir -p "${TMPDIR}"

                    trivy image \
                        --scanners vuln \
                        --severity HIGH,CRITICAL \
                        --ignore-unfixed \
                        --exit-code 0 \
                        --no-progress \
                        --format json \
                        --output "${WORKSPACE}/trivy-image-report.json" \
                        "${IMAGE_URI}"

                    echo ""
                    echo "-- Findings (HIGH / CRITICAL, fixed-only) ----"
                    trivy convert \
                        --format table \
                        --severity HIGH,CRITICAL \
                        --scanners vuln \
                        "${WORKSPACE}/trivy-image-report.json"

                    HIGH_CRIT_COUNT=$(jq '[.Results[]?.Vulnerabilities[]?] | length' "${WORKSPACE}/trivy-image-report.json")
                    echo ""
                    echo "Total HIGH/CRITICAL (fixed) findings in image: ${HIGH_CRIT_COUNT}"

                    if [ "${HIGH_CRIT_COUNT}" -gt 0 ]; then
                        echo "\\033[1;31mFAIL: ${HIGH_CRIT_COUNT} HIGH/CRITICAL vulnerabilities in image with available fixes.\\033[0m"
                        echo "Remediation: bump the base image tag in the Dockerfile (eclipse-temurin) and rebuild."
                        exit 1
                    fi                    echo "\\033[1;32mSUCCESS: No fixable HIGH/CRITICAL vulnerabilities in image.\\033[0m"
                '''
            }

            post {
                always {
                    script {
                        logWarning('Archiving trivy image report if available')
                    }

                    archiveArtifacts artifacts: 'trivy-image-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true

                    // Clean up the scratch dir we created to dodge /tmp tmpfs limits.
                    sh 'rm -rf "${WORKSPACE}/.trivy-tmp" || true'
                }
                success {
                    script {
                        logSuccess('Image Vulnerability Scan stage completed')
                    }
                }                failure {
                    script {
                        logError('Image Vulnerability Scan failed. Either fixable CVEs were found, or trivy errored.')
                    }
                }
            }
        }

        stage('ECR Login & Push') {
            steps {
                script {
                    stageHeader('ECR Login & Push')
                    logInfo("Target registry: ${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com")
                    logInfo("Pushing image  : ${env.IMAGE_URI}")
                }

                sh '''
                    set -e
                    echo "-- Pre-flight checks --------------------------"

                    if ! command -v aws >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: aws CLI is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    aws --version
                    echo ""
                    echo "Caller identity (must have ecr:* perms on this repo):"
                    aws sts get-caller-identity --output table

                    echo ""
                    echo "-- Docker login to ECR ------------------------"
                    # Short-lived (12h) auth token piped via stdin so it never
                    # appears in process args, shell history, or Jenkins logs.
                    aws ecr get-login-password --region "${AWS_REGION}" \
                        | docker login \
                            --username AWS \
                            --password-stdin \
                            "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

                    echo ""
                    echo "-- Pushing image ------------------------------"
                    echo "Image: ${IMAGE_URI}"
                    docker push "${IMAGE_URI}"

                    echo ""
                    echo "-- Verifying image in ECR ---------------------"
                    aws ecr describe-images \
                        --repository-name "shopease-webapp-development-${SERVICE_NAME}" \
                        --image-ids "imageTag=${GIT_SHA}" \
                        --region "${AWS_REGION}" \
                        --query 'imageDetails[0].{Tag:imageTags[0],Digest:imageDigest,Pushed:imagePushedAt,SizeMB:imageSizeInBytes}' \
                        --output table

                    echo ""
                    echo "\\033[1;32mSUCCESS: Image pushed and verified in ECR.\\033[0m"
                '''
            }

            post {
                success {
                    script {
                        logSuccess("ECR Push completed: ${env.IMAGE_URI}")
                    }
                }
                failure {
                    script {
                        logError('ECR Push failed. Common causes: IAM perms missing (ecr:PutImage / ecr:UploadLayerPart), repo does not exist, or network egress blocked.')
                    }
                }
                always {
                    // Always log out of the registry so the auth token in
                    // ~/.docker/config.json does not linger between builds.
                    sh '''
                        docker logout "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com" || true
                    '''
                }
            }
        }

        stage('Post-Build Cleanup & Summary') {
            steps {
                script {
                    stageHeader('Post-Build Cleanup & Summary')
                }

                sh '''
                    set +e
                    echo "-- Removing local image -----------------------"
                    # Image is safely in ECR now; no reason to keep it on the
                    # Jenkins host. Leaving images behind fills the disk after
                    # a few dozen builds on a bare-metal agent.
                    docker rmi "${IMAGE_URI}" || true

                    echo ""
                    echo "-- Pruning dangling layers --------------------"
                    # Surgical: only dangling (untagged) intermediate layers.
                    # We intentionally do NOT run 'docker system prune -a'
                    # because that would wipe the base-image cache
                    # (eclipse-temurin, maven) and force a ~500MB re-pull
                    # on the next build.
                    docker image prune -f

                    echo ""
                    echo "-- Disk usage ---------------------------------"
                    df -h / | tail -2
                    docker system df
                '''

                script {
                    echo color('1;36', """
============================================================
 BUILD SUMMARY
============================================================
 Service     : ${env.SERVICE_NAME}
 Branch      : ${env.BRANCH_NAME}
 Git SHA     : ${env.GIT_SHA}
 Image URI   : ${env.IMAGE_URI}
 Build #     : ${env.BUILD_NUMBER}
 Result      : ${currentBuild.currentResult}
============================================================
""")
                }
            }
        }
    }

    post {
        success {
            script {
                logSuccess("Pipeline completed successfully. Build #${env.BUILD_NUMBER}")
            }
        }

        failure {
            script {
                logError("Pipeline failed. Build #${env.BUILD_NUMBER}")
            }
        }

        unstable {
            script {
                logWarning("Pipeline unstable. Build #${env.BUILD_NUMBER}")
            }
        }

        always {
            script {
                logInfo("Build #${env.BUILD_NUMBER} finished with status: ${currentBuild.currentResult}")
            }
        }
    }
}

