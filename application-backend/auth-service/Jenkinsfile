def color(code, message) {
    return "\u001B[${code}m${message}\u001B[0m"
}

def stageHeader(String name) {
    echo color('1;36', """
============================================================
 STAGE STARTED: ${name}
============================================================
""")
}

def success(String message) {
    echo color('1;32', "SUCCESS: ${message}")
}

def warn(String message) {
    echo color('1;33', "WARNING: ${message}")
}

def info(String message) {
    echo color('1;34', "INFO: ${message}")
}

def errorMsg(String message) {
    echo color('1;31', "ERROR: ${message}")
}

pipeline {
    agent any

    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '3', daysToKeepStr: '30'))
    }

    environment {
        SERVICE_NAME   = 'auth-service'
        AWS_REGION     = 'ap-south-1'
        AWS_ACCOUNT_ID = '483829975256'
        ECR_REPO       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/shopease-webapp-development-${SERVICE_NAME}"
    }

    stages {

        stage('Setup & Environment') {
            steps {
                script {
                    stageHeader('Setup & Environment')

                    env.GIT_SHA   = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG = "${env.GIT_SHA}"
                    env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                    info("Service   : ${env.SERVICE_NAME}")
                    info("Branch    : ${env.BRANCH_NAME}")
                    info("Git SHA   : ${env.GIT_SHA}")
                    info("Image URI : ${env.IMAGE_URI}")
                    info("Workspace : ${env.WORKSPACE}")

                    success('Setup & Environment completed')
                }
            }
        }

        stage('Secret Scan') {
            steps {
                script {
                    stageHeader('Secret Scan')
                }

                sh '''
                    echo "-- Running gitleaks ---------------------------"

                    if ! command -v gitleaks >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: gitleaks is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    gitleaks version

                    gitleaks detect \
                        --source="${WORKSPACE}" \
                        --no-git \
                        --report-format=json \
                        --report-path="${WORKSPACE}/gitleaks-report.json" \
                        --redact \
                        --verbose \
                        --exit-code=1

                    echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                '''
            }

            post {
                always {
                    script {
                        warn('Archiving gitleaks report if available')
                    }

                    archiveArtifacts artifacts: 'gitleaks-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }

                success {
                    script {
                        success('Secret Scan stage completed')
                    }
                }                failure {
                    script {
                        errorMsg('Secret Scan failed. Secrets may be detected or gitleaks encountered an error')
                    }
                }
            }
        }

        stage('Dependency Vulnerability Scan') {
            steps {
                script {
                    stageHeader('Dependency Vulnerability Scan (Trivy fs)')
                }

                sh '''
                    echo "-- Running trivy fs ---------------------------"

                    if ! command -v trivy >/dev/null 2>&1; then
                        echo "\\033[1;31mERROR: trivy is not installed on Jenkins agent.\\033[0m"
                        exit 1
                    fi

                    trivy --version

                    trivy fs \
                        --scanners vuln \
                        --severity HIGH,CRITICAL \
                        --exit-code 1 \
                        --no-progress \
                        --format json \
                        --output "${WORKSPACE}/trivy-fs-report.json" \
                        application-backend/auth-service

                    echo "\\033[1;32mSUCCESS: No HIGH/CRITICAL vulnerabilities in dependencies.\\033[0m"
                '''
            }

            post {
                always {
                    script {
                        warn('Archiving trivy fs report if available')
                    }

                    archiveArtifacts artifacts: 'trivy-fs-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }

                success {
                    script {
                        success('Dependency Vulnerability Scan stage completed')
                    }
                }

                failure {
                    script {
                        errorMsg('Dependency Vulnerability Scan failed. HIGH/CRITICAL CVEs found or trivy errored')
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                success("Pipeline completed successfully. Build #${env.BUILD_NUMBER}")
            }
        }

        failure {
            script {
                errorMsg("Pipeline failed. Build #${env.BUILD_NUMBER}")
            }
        }

        unstable {
            script {
                warn("Pipeline unstable. Build #${env.BUILD_NUMBER}")
            }
        }

        always {
            script {
                info("Build #${env.BUILD_NUMBER} finished with status: ${currentBuild.currentResult}")
            }
        }
    }
}

