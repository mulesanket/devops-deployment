@Library('shopease-jenkins-library') _

pipeline {
    agent {
        kubernetes {
            yaml shopeaseAgent(serviceName: 'auth-service')
            defaultContainer 'jnlp'
            showRawYaml false
        }
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '5', daysToKeepStr: '30'))
    }    

    environment {
        SERVICE_NAME    = 'auth-service'
        AWS_REGION      = 'ap-south-1'
        ECR_REPO_NAME   = "shopease-webapp-development-${SERVICE_NAME}"
        SAFE_BRANCH     = "${env.BRANCH_NAME ?: env.GIT_BRANCH?.replaceAll('^origin/', '') ?: 'development'}"
        ARTIFACT_BUCKET = 'shopease-webapp-development-ci-artifacts'
    }

    stages {

        stage('Setup & Environment') {
            steps {
                container('aws') {
                    script {
                        logger.stageHeader('Setup & Environment')

                        env.AWS_ACCOUNT_ID = sh(
                            script: 'aws sts get-caller-identity --query Account --output text',
                            returnStdout: true
                        ).trim()

                        env.ECR_REPO  = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com/${env.ECR_REPO_NAME}"
                        env.GIT_SHA   = (env.GIT_COMMIT ?: 'unknown').take(7)
                        env.IMAGE_TAG = "${env.GIT_SHA}"
                        env.IMAGE_URI = "${env.ECR_REPO}:${env.IMAGE_TAG}"

                        logger.logInfo("Service     : ${env.SERVICE_NAME}")
                        logger.logInfo("AWS Account : ${env.AWS_ACCOUNT_ID}")
                        logger.logInfo("AWS Region  : ${env.AWS_REGION}")
                        logger.logInfo("Branch      : ${env.BRANCH_NAME}")
                        logger.logInfo("Git SHA     : ${env.GIT_SHA}")
                        logger.logInfo("Image URI   : ${env.IMAGE_URI}")
                        logger.logInfo("Workspace   : ${env.WORKSPACE}")
                        logger.logInfo("Pod node    : ${env.NODE_NAME}")

                        sh '''
                            echo "-- IRSA caller identity (should be ci-agent-irsa) --"
                            aws sts get-caller-identity --output table
                        '''

                        logger.logSuccess('Setup & Environment completed')
                    }
                }
            }
        }

        stage('Secret Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Secret Scan - Trivy secret') }

                    sh '''
                        set -e
                        echo "-- Running trivy secret scan ------------------"
                        trivy --version
                        trivy fs \
                            --scanners secret \
                            --exit-code 1 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-secrets-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Secret findings ----------------------------"
                        trivy convert \
                            --format table \
                            "${WORKSPACE}/trivy-secrets-report.json"

                        echo "\\033[1;32mSUCCESS: No secrets detected.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy secret report if available') }
                    archiveArtifacts artifacts: 'trivy-secrets-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
                failure { script { logger.logError('Secret scan failed: secrets detected. Inspect the archived report.') } }
            }
        }

        stage('Dependency Vulnerability Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Dependency Vulnerability Scan - Trivy fs') }

                    sh '''
                        set -e
                        echo "-- Running trivy fs (vuln) --------------------"
                        trivy --version
                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 0 \
                            --no-progress \
                            --format json \
                            --output "${WORKSPACE}/trivy-fs-report.json" \
                            "application-backend/${SERVICE_NAME}"

                        echo ""
                        echo "-- Findings (HIGH / CRITICAL only) ------------"
                        trivy convert \
                            --format table \
                            --severity HIGH,CRITICAL \
                            "${WORKSPACE}/trivy-fs-report.json"

                        echo ""
                        echo "-- Gate (fail on any HIGH/CRITICAL) -----------"
                        trivy fs \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --exit-code 1 \
                            --no-progress \
                            --quiet \
                            "application-backend/${SERVICE_NAME}"

                        echo "\\033[1;32mSUCCESS: No HIGH/CRITICAL vulnerabilities in dependencies.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy fs report if available') }
                    archiveArtifacts artifacts: 'trivy-fs-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Build & Unit Tests') {
            steps {
                container('maven') {
                    script {
                        logger.stageHeader('Build & Unit Tests')
                        logger.logInfo('Running mvn verify inside maven container')
                    }

                    sh '''
                        set -e
                        echo "-- Toolchain ----------------------------------"
                        mvn -v

                        echo ""
                        echo "-- Running mvn verify -------------------------"
                        cd application-backend
                        mvn -pl ${SERVICE_NAME} -am -B -ntp verify

                        echo ""
                        echo "-- Test report locations ----------------------"
                        find . -type d -name surefire-reports | head -20
                        find . -type f -name jacoco.xml      | head -20

                        echo "\\033[1;32mSUCCESS: Build and unit tests completed.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Publishing JUnit results and coverage reports') }
                    junit testResults: 'application-backend/**/target/surefire-reports/*.xml',
                          allowEmptyResults: false,
                          skipPublishingChecks: true
                }
            }
        }

        stage('Image Build & Push') {
            steps {
                container('kaniko') {
                    script {
                        logger.stageHeader('Image Build & Push (Kaniko)')
                        logger.logInfo("Building & pushing : ${env.IMAGE_URI}")
                    }
                                        
                    sh '''
                        set -e
                        /kaniko/executor \
                            --context "${WORKSPACE}/application-backend" \
                            --dockerfile "${SERVICE_NAME}/Dockerfile" \
                            --destination "${IMAGE_URI}" \
                            --label "git.sha=${GIT_SHA}" \
                            --label "git.branch=${SAFE_BRANCH}" \
                            --label "build.number=${BUILD_NUMBER}" \
                            --label "service=${SERVICE_NAME}" \
                            --snapshot-mode=redo \
                            --use-new-run \
                            --log-format=text \
                            --verbosity=info
                    '''
                }
            }
        }

        stage('Image Vulnerability Scan') {
            steps {
                container('tools') {
                    script { logger.stageHeader('Image Vulnerability Scan - Trivy image (ECR)') }

                    retry(2) {
                        sh '''
                            set -e
                            echo "-- Running trivy image ------------------------"
                            trivy --version

                            export TMPDIR="${WORKSPACE}/.trivy-tmp"
                            mkdir -p "${TMPDIR}"

                            trivy image \
                                --scanners vuln \
                                --severity HIGH,CRITICAL \
                                --ignore-unfixed \
                                --exit-code 0 \
                                --no-progress \
                                --format json \
                                --output "${WORKSPACE}/trivy-image-report.json" \
                                "${IMAGE_URI}"
                        '''
                    }

                    sh '''
                        set -e
                        echo ""
                        echo "-- Findings (HIGH / CRITICAL, fixed-only) -----"
                        trivy convert \
                            --format table \
                            --severity HIGH,CRITICAL \
                            "${WORKSPACE}/trivy-image-report.json"

                        echo ""
                        echo "-- Gate (fail on fixable HIGH/CRITICAL) -------"
                        trivy image \
                            --scanners vuln \
                            --severity HIGH,CRITICAL \
                            --ignore-unfixed \
                            --exit-code 1 \
                            --no-progress \
                            --quiet \
                            "${IMAGE_URI}"

                        echo "\\033[1;32mSUCCESS: No fixable HIGH/CRITICAL vulnerabilities in image.\\033[0m"
                    '''
                }
            }
            post {
                always {
                    script { logger.logWarning('Archiving trivy image report if available') }
                    archiveArtifacts artifacts: 'trivy-image-report.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                    sh 'rm -rf "${WORKSPACE}/.trivy-tmp" || true'
                }
                success { script { logger.logSuccess('Image Vulnerability Scan stage completed') } }
                failure { script { logger.logError('Image Vulnerability Scan failed: fixable CVEs found or trivy errored.') } }
            }
        }

        stage('Publish Artifacts to S3') {
            steps {
                container('aws') {
                    script {
                        logger.stageHeader('Publish Artifacts to S3')
                        logger.logInfo("Bucket   : s3://${env.ARTIFACT_BUCKET}")
                        logger.logInfo("Prefix   : ${env.SERVICE_NAME}/")
                        logger.logInfo("Pattern  : ${env.SERVICE_NAME}-${env.GIT_SHA}-${env.BUILD_NUMBER}-<type>.<ext>")
                    }

                    sh '''
                        set -e

                        BASE="s3://${ARTIFACT_BUCKET}/${SERVICE_NAME}"
                        PREFIX="${SERVICE_NAME}-${GIT_SHA}-${BUILD_NUMBER}"

                        # ----------------------------------------------------
                        # 1. JAR artifact (from maven build output)
                        # ----------------------------------------------------
                        echo "-- Locating JAR ------------------------------"
                        JAR_FILE=$(find application-backend/${SERVICE_NAME}/target \
                            -maxdepth 1 -type f -name "*.jar" \
                            ! -name "*-sources.jar" ! -name "*-javadoc.jar" \
                            | head -1 || true)

                        if [ -n "${JAR_FILE}" ] && [ -f "${JAR_FILE}" ]; then
                            DEST="${BASE}/jars/${PREFIX}.jar"
                            echo "Uploading ${JAR_FILE} -> ${DEST}"
                            aws s3 cp "${JAR_FILE}" "${DEST}" \
                                --metadata "service=${SERVICE_NAME},git-sha=${GIT_SHA},build=${BUILD_NUMBER},branch=${SAFE_BRANCH}"
                        else
                            echo "WARN: no JAR found under target/ - skipping"
                        fi

                        # ----------------------------------------------------
                        # 2. Trivy reports
                        # ----------------------------------------------------
                        upload_report() {
                            SRC="$1"; SUBDIR="$2"; SUFFIX="$3"
                            if [ -f "${SRC}" ]; then
                                DEST="${BASE}/reports/${SUBDIR}/${PREFIX}-${SUFFIX}.json"
                                echo "Uploading ${SRC} -> ${DEST}"
                                aws s3 cp "${SRC}" "${DEST}" \
                                    --content-type application/json \
                                    --metadata "service=${SERVICE_NAME},git-sha=${GIT_SHA},build=${BUILD_NUMBER},report=${SUFFIX}"
                            else
                                echo "WARN: ${SRC} not found - skipping"
                            fi
                        }

                        echo ""
                        echo "-- Uploading scan reports --------------------"
                        upload_report "${WORKSPACE}/trivy-secrets-report.json" "secrets"      "secrets"
                        upload_report "${WORKSPACE}/trivy-fs-report.json"      "dependencies" "deps"
                        upload_report "${WORKSPACE}/trivy-image-report.json"   "image"        "image"

                        # ----------------------------------------------------
                        # 3. JUnit / surefire reports (tarball)
                        # ----------------------------------------------------
                        echo ""
                        echo "-- Bundling test reports ---------------------"
                        TEST_TGZ="${WORKSPACE}/${PREFIX}-junit.tar.gz"
                        if find application-backend/${SERVICE_NAME} -type d -name surefire-reports | grep -q .; then
                            tar -czf "${TEST_TGZ}" \
                                $(find application-backend/${SERVICE_NAME} -type d -name surefire-reports)
                            aws s3 cp "${TEST_TGZ}" "${BASE}/reports/tests/${PREFIX}-junit.tar.gz" \
                                --metadata "service=${SERVICE_NAME},git-sha=${GIT_SHA},build=${BUILD_NUMBER}"
                            rm -f "${TEST_TGZ}"
                        else
                            echo "WARN: no surefire-reports found - skipping"
                        fi

                        # ----------------------------------------------------
                        # 4. Build manifest (single source of truth)
                        # ----------------------------------------------------
                        echo ""
                        echo "-- Resolving image digest --------------------"
                        IMAGE_DIGEST=$(aws ecr describe-images \
                            --repository-name "${ECR_REPO_NAME}" \
                            --image-ids "imageTag=${GIT_SHA}" \
                            --region "${AWS_REGION}" \
                            --query 'imageDetails[0].imageDigest' \
                            --output text 2>/dev/null || echo "unknown")                        MANIFEST="${WORKSPACE}/${PREFIX}-manifest.json"
                        cat > "${MANIFEST}" <<EOF
{
  "service": "${SERVICE_NAME}",
  "branch": "${SAFE_BRANCH}",
  "gitSha": "${GIT_SHA}",
  "gitCommit": "${GIT_COMMIT}",
  "buildNumber": "${BUILD_NUMBER}",
  "buildUrl": "${BUILD_URL}",
  "jobName": "${JOB_NAME}",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "image": {
    "uri": "${IMAGE_URI}",
    "digest": "${IMAGE_DIGEST}"
  },
  "artifacts": {
    "jar":             "${BASE}/jars/${PREFIX}.jar",
    "secretsReport":   "${BASE}/reports/secrets/${PREFIX}-secrets.json",
    "depsReport":      "${BASE}/reports/dependencies/${PREFIX}-deps.json",
    "imageReport":     "${BASE}/reports/image/${PREFIX}-image.json",
    "testReports":     "${BASE}/reports/tests/${PREFIX}-junit.tar.gz"
  }
}
EOF

                        echo "Uploading manifest -> ${BASE}/manifests/${PREFIX}-manifest.json"
                        aws s3 cp "${MANIFEST}" "${BASE}/manifests/${PREFIX}-manifest.json" \
                            --content-type application/json \
                            --metadata "service=${SERVICE_NAME},git-sha=${GIT_SHA},build=${BUILD_NUMBER}"

                        # ----------------------------------------------------
                        # 5. Floating pointer: latest successful build per branch
                        #    ECR tags are IMMUTABLE, so the "latest" concept
                        #    lives in S3 (versioned + auditable) instead.
                        #    Deployments resolve gitSha from this file, then
                        #    pull the immutable :<gitSha> tag from ECR.
                        # ----------------------------------------------------
                        echo ""
                        echo "-- Updating branch pointer -------------------"
                        POINTER="${WORKSPACE}/${SAFE_BRANCH}-latest.json"
                        cat > "${POINTER}" <<EOF
{
  "service": "${SERVICE_NAME}",
  "branch": "${SAFE_BRANCH}",
  "gitSha": "${GIT_SHA}",
  "buildNumber": "${BUILD_NUMBER}",
  "imageUri": "${IMAGE_URI}",
  "imageDigest": "${IMAGE_DIGEST}",
  "manifest": "${BASE}/manifests/${PREFIX}-manifest.json",
  "updatedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

                        aws s3 cp "${POINTER}" "${BASE}/latest/${SAFE_BRANCH}.json" \
                            --content-type application/json \
                            --metadata "service=${SERVICE_NAME},branch=${SAFE_BRANCH},git-sha=${GIT_SHA}"
                        rm -f "${POINTER}"

                        echo ""
                        echo "-- Listing uploaded objects ------------------"
                        aws s3 ls "${BASE}/" --recursive --human-readable | grep "${PREFIX}" || true

                        echo "SUCCESS: All artifacts published to S3."
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_NAME}-${env.GIT_SHA}-${env.BUILD_NUMBER}-manifest.json",
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
                success { script { logger.logSuccess('Artifacts published to S3') } }
                failure { script { logger.logError('S3 publish failed - check IRSA s3:PutObject perms') } }
            }
        }

        stage('Verify ECR Push') {
            steps {
                container('aws') {
                    sh '''
                        aws ecr describe-images \
                            --repository-name "${ECR_REPO_NAME}" \
                            --image-ids "imageTag=${GIT_SHA}" \
                            --region "${AWS_REGION}"
                    '''
                }
            }
        }

        stage('Build Summary') {
            steps {
                script {
                    echo """
============================================================
 BUILD SUMMARY
============================================================
 Service     : ${env.SERVICE_NAME}
 Branch      : ${env.BRANCH_NAME} Git SHA     : ${env.GIT_SHA}
 Image URI   : ${env.IMAGE_URI}
 Build #     : ${env.BUILD_NUMBER}
 Agent pod   : ${env.NODE_NAME}
 Artifacts   : s3://${env.ARTIFACT_BUCKET}/${env.SERVICE_NAME}/ (prefix: ${env.SERVICE_NAME}-${env.GIT_SHA}-${env.BUILD_NUMBER})
 Result      : ${currentBuild.currentResult}
============================================================
"""
                }
            }
        }
    }
}